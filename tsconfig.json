{
	"$schema": "https://www.schemastore.org/tsconfig.json",
	"compilerOptions": {
		"declaration": true,
		"esModuleInterop": true,
		"erasableSyntaxOnly": true,
		"rewriteRelativeImportExtensions": true,
		"resolveJsonModule": true,
		"moduleResolution": "NodeNext",
		"module": "NodeNext",
		"target": "es2024",
		"lib": ["ES2024"],
		"outDir": "./dist",
		"rootDir": "lib/",
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": [
		"lib"
	],
	"exclude": [
		"dist",
		"**/*.spec.ts",
		"**/*.test.ts"
	]
}
